---
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, CONTACT, AREAS_SERVED } from '../data/site';

export interface Props {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const { title, description, path, ogImage, ogType, noindex } = Astro.props;

// ── Datos estructurados (schema.org) para SEO local / GEO ──
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  '@id': `${SITE.url}/#organization`,
  name: SITE.legalName,
  alternateName: 'Sofía 54',
  url: SITE.url,
  description: SITE.description,
  email: CONTACT.email,
  telephone: CONTACT.phone,
  priceRange: '€€',
  areaServed: AREAS_SERVED.map((a) => ({ '@type': 'Place', name: a })),
  address: {
    '@type': 'PostalAddress',
    streetAddress: CONTACT.address.street,
    postalCode: CONTACT.address.postalCode,
    addressLocality: CONTACT.address.city,
    addressRegion: CONTACT.address.region,
    addressCountry: CONTACT.address.country,
  },
  knowsAbout: [
    'Alquiler de naves industriales',
    'Gestión de naves industriales',
    'Naves logísticas',
    'Espacios industriales en la Comunidad de Madrid',
  ],
  slogan: 'Espacios industriales a tu medida',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  inLanguage: 'es-ES',
  publisher: { '@id': `${SITE.url}/#organization` },
};
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <Seo
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(orgSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <style is:global>
      :root {
        --gs-blue: #2246f5;
        --gs-ink: #1a1d2e;
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI',
          Arial, sans-serif;
        color: var(--gs-ink);
        background: #ffffff;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      main {
        min-height: 50vh;
      }
      img {
        max-width: 100%;
      }
      a {
        color: var(--gs-blue);
      }
    </style>
  </body>
</html>
