---
import { SITE, CONTACT, BRAND } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="gs54-site-footer">
  <div class="gs54-site-footer-inner">
    <div class="gs54-footer-brand">
      <img src={BRAND.logoWhite} alt={SITE.name} width="180" height="50" />
      <blockquote class="gs54-footer-tagline">{SITE.tagline}</blockquote>
    </div>

    <div class="gs54-footer-col">
      <h3>Enlaces</h3>
      <ul>
        <li><a href="/">Inicio</a></li>
        <li><a href="/sobre-nosotros/">Sobre Nosotros</a></li>
        <li><a href="/nuestras-naves/">Nuestras Naves</a></li>
        <li><a href="/contacto/">Contacto</a></li>
      </ul>
    </div>

    <div class="gs54-footer-col">
      <h3>Legal Y Privacidad</h3>
      <ul>
        <li><a href="/aviso-legal/">Aviso Legal</a></li>
        <li><a href="/politica-de-privacidad/">Política de Privacidad</a></li>
        <li><a href="/politica-de-cookies/">Política de Cookies</a></li>
      </ul>
    </div>

    <div class="gs54-footer-col">
      <h3>Contacto Directo</h3>
      <ul class="gs54-footer-contact">
        <li>📍 {CONTACT.address.street}</li>
        <li>
          📞 <a href={`tel:${CONTACT.phoneRaw}`}>{CONTACT.phone}</a>
        </li>
        <li>
          ✉️ <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        </li>
        <li>🕐 <a href="/contacto/">Contacta para visitarnos</a></li>
      </ul>
    </div>
  </div>

  <div class="gs54-site-footer-bottom">
    <p>Copyright © {year} {SITE.name} · Powered by Vionyx</p>
  </div>
</footer>

<style>
  .gs54-site-footer {
    background: #0f1117;
    color: #c3c7d4;
    border-top: 1px solid #1c1f2b;
  }
  .gs54-site-footer-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 64px 32px 40px;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
    gap: 40px;
  }
  .gs54-footer-brand img {
    height: 46px;
    width: auto;
    margin-bottom: 20px;
    display: block;
  }
  .gs54-footer-tagline {
    border-left: 3px solid #2246f5;
    padding-left: 16px;
    margin: 0;
    font-style: italic;
    font-size: 0.88rem;
    line-height: 1.6;
    color: #9298b0;
    max-width: 320px;
  }
  .gs54-footer-col h3 {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6b7088;
    margin: 0 0 18px;
  }
  .gs54-footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .gs54-footer-col a {
    color: #c3c7d4;
    text-decoration: none;
    font-size: 0.88rem;
    transition: color 0.17s;
  }
  .gs54-footer-col a:hover {
    color: #ffffff;
  }
  .gs54-footer-contact li {
    font-size: 0.86rem;
    line-height: 1.5;
  }
  .gs54-site-footer-bottom {
    border-top: 1px solid #1c1f2b;
    padding: 22px 32px;
    text-align: center;
  }
  .gs54-site-footer-bottom p {
    margin: 0;
    font-size: 0.8rem;
    color: #6b7088;
  }

  @media (max-width: 820px) {
    .gs54-site-footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }
    .gs54-footer-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 520px) {
    .gs54-site-footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
