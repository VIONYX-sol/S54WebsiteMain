---
import { SITE, BRAND } from '../data/site';

const nav = [
  { label: 'Inicio', href: '/' },
  { label: 'Nuestras Naves', href: '/nuestras-naves/' },
  { label: 'Sobre Nosotros', href: '/sobre-nosotros/' },
  { label: 'Contacto', href: '/contacto/' },
];

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header class="gs54-site-header">
  <div class="gs54-site-header-inner">
    <a href="/" class="gs54-site-logo" aria-label={`${SITE.name} — Inicio`}>
      <img
        class="gs54-logo gs54-logo-white"
        src={BRAND.logoWhite}
        alt={SITE.name}
        width="184"
        height="52"
      />
      <img
        class="gs54-logo gs54-logo-dark"
        src={BRAND.logoDark}
        alt={SITE.name}
        width="184"
        height="52"
      />
    </a>

    <nav class="gs54-site-nav" aria-label="Navegación principal">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={['gs54-site-nav-link', { active: isActive(item.href) }]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="gs54-site-actions">
      <a class="gs54-site-cta" href="/contacto/">
        Consultar nave
      </a>
      <button
        class="gs54-site-burger"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="gs54-mobile-menu"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav id="gs54-mobile-menu" class="gs54-site-mobile" aria-label="Navegación móvil">
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={['gs54-site-mobile-link', { active: isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))
    }
    <a class="gs54-site-mobile-cta" href="/contacto/">
      Consultar nave
    </a>
  </nav>
</header>

<style>
  .gs54-site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    height: 72px;
    background: transparent;
    border-bottom: none;
    box-shadow: none;
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  .gs54-site-header.scrolled {
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #e0e3ef;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
  }
  .gs54-site-header-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 32px;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .gs54-site-logo {
    display: inline-flex;
    align-items: center;
    flex: none;
    line-height: 0;
  }
  .gs54-logo {
    height: 52px;
    width: auto;
    display: block;
  }
  .gs54-logo-dark {
    display: none;
  }
  .gs54-site-header.scrolled .gs54-logo-white {
    display: none;
  }
  .gs54-site-header.scrolled .gs54-logo-dark {
    display: block;
  }
  .gs54-site-nav {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }
  .gs54-site-nav-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.88);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    line-height: 1.2;
  }
  .gs54-site-nav-link:hover {
    color: #ffffff;
  }
  .gs54-site-header.scrolled .gs54-site-nav-link {
    color: #5a5f78;
  }
  .gs54-site-header.scrolled .gs54-site-nav-link:hover {
    color: #2246f5;
  }
  .gs54-site-nav-link.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    border-bottom: 2px solid currentColor;
  }
  .gs54-site-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: none;
  }
  .gs54-site-cta {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    color: #fff;
    background: #2246f5;
    border-radius: 6px;
    padding: 9px 20px;
    transition: background 0.2s ease;
  }
  .gs54-site-cta:hover {
    background: #1535c4;
  }
  .gs54-site-burger {
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    padding: 0;
    cursor: pointer;
    color: #ffffff;
  }
  .gs54-site-header.scrolled .gs54-site-burger {
    color: #1a1d2e;
  }
  .gs54-site-burger span {
    width: 22px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: all 0.25s ease;
  }
  .gs54-site-burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .gs54-site-burger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .gs54-site-burger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .gs54-site-mobile {
    display: none;
  }

  @media (max-width: 860px) {
    .gs54-site-header-inner {
      padding: 0 20px;
    }
    .gs54-site-nav,
    .gs54-site-cta {
      display: none;
    }
    .gs54-site-burger {
      display: inline-flex;
    }
    .gs54-site-mobile {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background: #fff;
      border-bottom: 1px solid #e0e3ef;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
      padding: 14px 20px 18px;
      flex-direction: column;
      gap: 2px;
    }
    .gs54-site-mobile.open {
      display: flex;
    }
    .gs54-site-mobile-link {
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      font-weight: 500;
      color: #1a1d2e;
      text-decoration: none;
      padding: 12px 0;
      border-bottom: 1px solid #f1f3fa;
      position: relative;
    }
    .gs54-site-mobile-link.active {
      color: #2246f5;
    }
    .gs54-site-mobile-cta {
      margin-top: 12px;
      text-align: center;
      font-family: 'Inter', sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      text-decoration: none;
      color: #fff;
      background: #2246f5;
      border-radius: 6px;
      padding: 11px 16px;
    }
    .gs54-site-mobile-cta:hover {
      background: #1535c4;
    }
  }
</style>

<script>
  const header = document.querySelector('.gs54-site-header');
  const burger = document.querySelector('.gs54-site-burger');
  const menu = document.getElementById('gs54-mobile-menu');
  const mobileLinks = menu?.querySelectorAll('a');

  const syncHeaderState = () => {
    header?.classList.toggle('scrolled', window.scrollY > 60);
  };

  const closeMenu = () => {
    menu?.classList.remove('open');
    burger?.setAttribute('aria-expanded', 'false');
    burger?.setAttribute('aria-label', 'Abrir menú');
  };

  syncHeaderState();
  window.addEventListener('scroll', syncHeaderState, { passive: true });

  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    burger.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 860) closeMenu();
  });
</script>
