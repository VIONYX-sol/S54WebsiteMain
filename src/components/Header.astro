---
import { SITE, BRAND } from '../data/site';

const nav = [
  { label: 'Inicio', href: '/' },
  { label: 'Nuestras Naves', href: '/nuestras-naves/' },
  { label: 'Sobre Nosotros', href: '/sobre-nosotros/' },
  { label: 'Contacto', href: '/contacto/' },
];

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header class="gs54-site-header">
  <div class="gs54-site-header-inner">
    <a href="/" class="gs54-site-logo" aria-label={`${SITE.name} — Inicio`}>
      <img src={BRAND.logoDark} alt={SITE.name} width="170" height="48" />
    </a>

    <nav class="gs54-site-nav" aria-label="Navegación principal">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={['gs54-site-nav-link', { active: isActive(item.href) }]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <button
      class="gs54-site-burger"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="gs54-mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav id="gs54-mobile-menu" class="gs54-site-mobile" aria-label="Navegación móvil">
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={['gs54-site-mobile-link', { active: isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .gs54-site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #e0e3ef;
  }
  .gs54-site-header-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 32px;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .gs54-site-logo {
    display: inline-flex;
    align-items: center;
  }
  .gs54-site-logo img {
    height: 40px;
    width: auto;
    display: block;
  }
  .gs54-site-nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .gs54-site-nav-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: #5a5f78;
    text-decoration: none;
    transition: color 0.17s;
    position: relative;
  }
  .gs54-site-nav-link:hover {
    color: #2246f5;
  }
  .gs54-site-nav-link.active {
    color: #1a1d2e;
    font-weight: 600;
  }
  .gs54-site-nav-link.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -24px;
    height: 2px;
    background: #2246f5;
  }
  .gs54-site-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .gs54-site-burger span {
    width: 24px;
    height: 2px;
    background: #1a1d2e;
    border-radius: 2px;
    transition: all 0.25s;
  }
  .gs54-site-burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .gs54-site-burger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .gs54-site-burger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .gs54-site-mobile {
    display: none;
    flex-direction: column;
    border-top: 1px solid #e0e3ef;
    background: #ffffff;
    padding: 8px 32px 16px;
  }
  .gs54-site-mobile.open {
    display: flex;
  }
  .gs54-site-mobile-link {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #5a5f78;
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid #f0f1f6;
  }
  .gs54-site-mobile-link.active {
    color: #2246f5;
    font-weight: 600;
  }

  @media (max-width: 820px) {
    .gs54-site-nav {
      display: none;
    }
    .gs54-site-burger {
      display: flex;
    }
  }
</style>

<script>
  const burger = document.querySelector('.gs54-site-burger');
  const menu = document.getElementById('gs54-mobile-menu');
  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    burger.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  });
</script>
