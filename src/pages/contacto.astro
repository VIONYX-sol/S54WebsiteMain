---
import Base from '../layouts/Base.astro';
import { CONTACT, CONTACT_API_ENDPOINT } from '../data/site';
import '../styles/pages.css';

const description =
  '¿Buscas una nave industrial en la Comunidad de Madrid? Contacta con Grupo Sofía54: Calle Rodríguez San Pedro 23, Madrid · +34 914 475 113 · administracion@gruposofia54.com.';

const mapsQuery = encodeURIComponent(
  `${CONTACT.address.street}, ${CONTACT.address.postalCode} ${CONTACT.address.city}`
);
---

<Base title="Contacto" description={description} path="/contacto/">
  <div class="pg ct">
    <header class="pg-hero ct-hero">
      <div class="pg-container">
        <span class="pg-eyebrow"><span></span>Contacto</span>
        <h1 class="pg-hero-title">Cuéntanos qué espacio necesitas</h1>
        <p class="pg-hero-sub">
          Te ayudamos a encontrar una nave adaptada a tu actividad, tiempos y
          necesidades operativas.
        </p>
      </div>
    </header>

    <section class="pg-section">
      <div class="pg-container ct-layout">
        <div class="ct-info">
          <h2 class="pg-section-title" style="font-size:1.45rem;">Canales directos</h2>

          <a class="ct-line" href={`https://www.google.com/maps/search/?api=1&query=${mapsQuery}`} target="_blank" rel="noopener">
            <span class="ct-ic">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span>
              <strong>Oficina</strong>
              {CONTACT.address.street}, {CONTACT.address.postalCode}, {CONTACT.address.city}
            </span>
          </a>

          <a class="ct-line" href={`tel:${CONTACT.phoneRaw}`}>
            <span class="ct-ic">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <span>
              <strong>Teléfono</strong>
              {CONTACT.phone}
            </span>
          </a>

          <a class="ct-line" href={`mailto:${CONTACT.email}`}>
            <span class="ct-ic">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
            </span>
            <span>
              <strong>Email</strong>
              {CONTACT.email}
            </span>
          </a>

          <div class="ct-note">
            <h3>Respuesta ágil y personalizada</h3>
            <p>
              Nuestro equipo revisa cada solicitud para proponerte una solución
              concreta y viable según tu operativa.
            </p>
          </div>
        </div>

        <div class="ct-form-wrap">
          <h2 class="pg-section-title" style="font-size:1.45rem; margin-bottom:12px;">Formulario de contacto</h2>
          <p class="ct-form-sub">Recibirás confirmación automática en tu email tras el envío.</p>
          <form id="ct-form" class="ct-form">
            <div class="ct-field">
              <label for="nombre">Nombre</label>
              <input type="text" id="nombre" name="nombre" required autocomplete="name" />
            </div>
            <div class="ct-field">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
            <div class="ct-field">
              <label for="telefono">Teléfono <span>(opcional)</span></label>
              <input type="tel" id="telefono" name="telefono" autocomplete="tel" />
            </div>
            <div class="ct-field">
              <label for="mensaje">¿Qué nave buscas o en qué podemos ayudarte?</label>
              <textarea id="mensaje" name="mensaje" rows="4" required></textarea>
            </div>
            <button type="submit" class="ct-submit">Enviar mensaje</button>
            <p id="ct-status" class="ct-status" hidden></p>
          </form>
        </div>
      </div>
    </section>

    <section class="pg-section pg-section--surface">
      <div class="pg-container">
        <h2 class="pg-section-title">Equipo de contacto directo</h2>
        <div class="pg-grid pg-grid--4">
          {
            CONTACT.team.map((p) => (
              <article class="pg-card">
                <h3 class="pg-card-title">{p.name}</h3>
                <p class="pg-card-role">{p.role}</p>
                <p class="pg-card-desc">
                  <a href={`mailto:${p.email}`}>{p.email}</a>
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .ct-hero {
    background: linear-gradient(180deg, #fff, #f7f9fd);
  }
  .ct-layout {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 34px;
    align-items: start;
  }
  .ct-info {
    background: #fff;
    border: 1px solid #e0e3ef;
    border-radius: 16px;
    padding: 24px;
  }
  .ct-line {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    text-decoration: none;
    color: #1a1d2e;
    padding: 15px 0;
    border-bottom: 1px solid #eef1f6;
  }
  .ct-line strong {
    display: block;
    font-size: 0.98rem;
    margin-bottom: 4px;
  }
  .ct-line span:last-child {
    color: #5a5f78;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .ct-ic {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: #e8eefa;
    color: #2246f5;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ct-note {
    margin-top: 18px;
    border: 1px solid #dbe4ff;
    background: #f5f8ff;
    border-radius: 12px;
    padding: 14px;
  }
  .ct-note h3 {
    margin: 0 0 6px;
    font-size: 0.95rem;
    color: #1a1d2e;
  }
  .ct-note p {
    margin: 0;
    font-size: 0.86rem;
    color: #5a5f78;
    line-height: 1.55;
  }
  .ct-form-wrap {
    background: #fff;
    border: 1px solid #e0e3ef;
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 16px 45px rgba(34, 70, 245, 0.09);
  }
  .ct-form-sub {
    margin: 0 0 16px;
    color: #5a5f78;
    font-size: 0.88rem;
  }
  .ct-field {
    margin-bottom: 14px;
  }
  .ct-field label {
    display: block;
    font-size: 0.84rem;
    font-weight: 600;
    color: #1a1d2e;
    margin-bottom: 6px;
  }
  .ct-field label span {
    font-weight: 400;
    color: #9298b0;
  }
  .ct-field input,
  .ct-field textarea {
    width: 100%;
    border: 1px solid #e0e3ef;
    border-radius: 10px;
    padding: 11px 13px;
    font: inherit;
    font-size: 0.92rem;
    color: #1a1d2e;
    background: #fbfbfe;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }
  .ct-field input:focus,
  .ct-field textarea:focus {
    outline: none;
    border-color: #2246f5;
    box-shadow: 0 0 0 3px rgba(34, 70, 245, 0.12);
  }
  .ct-field textarea {
    resize: vertical;
  }
  .ct-submit {
    width: 100%;
    border: none;
    background: #2246f5;
    color: #fff;
    font: inherit;
    font-weight: 700;
    font-size: 0.93rem;
    padding: 13px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.17s;
  }
  .ct-submit:hover {
    background: #1535c4;
  }
  .ct-submit:disabled {
    opacity: 0.6;
    cursor: default;
  }
  .ct-status {
    margin: 12px 0 0;
    font-size: 0.9rem;
    text-align: center;
  }
  .ct-status.ok {
    color: #1a7f37;
  }
  .ct-status.err {
    color: #cf222e;
  }
  @media (max-width: 860px) {
    .ct-layout {
      grid-template-columns: 1fr;
    }
    .ct-form-wrap,
    .ct-info {
      padding: 22px;
    }
  }
</style>

<script define:vars={{ endpoint: CONTACT_API_ENDPOINT, to: CONTACT.email }}>
  const form = document.getElementById('ct-form');
  const status = document.getElementById('ct-status');

  function show(msg, ok) {
    status.hidden = false;
    status.textContent = msg;
    status.className = 'ct-status ' + (ok ? 'ok' : 'err');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form).entries());
    const btn = form.querySelector('button[type="submit"]');

    if (!endpoint) {
      const subject = encodeURIComponent('Consulta web — ' + (data.nombre || ''));
      const body = encodeURIComponent(
        `Nombre: ${data.nombre || ''}\n` +
          `Email: ${data.email || ''}\n` +
          `Teléfono: ${data.telefono || ''}\n\n` +
          `${data.mensaje || ''}`
      );
      window.location.href = `mailto:${to}?subject=${subject}&body=${body}`;
      show('Abriendo tu gestor de correo para enviar el mensaje…', true);
      return;
    }

    try {
      btn.disabled = true;
      btn.textContent = 'Enviando…';
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        form.reset();
        show('¡Gracias! Hemos recibido tu mensaje y te hemos enviado confirmación por email.', true);
      } else {
        show('No se pudo enviar. Escríbenos a ' + to, false);
      }
    } catch {
      show('No se pudo enviar. Escríbenos a ' + to, false);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar mensaje';
    }
  });
</script>
