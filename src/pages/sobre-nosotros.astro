---
import Base from '../layouts/Base.astro';
import '../styles/pages.css';
import { MEDIA_BASE } from '../data/site';

const description =
  'Grupo Sofía54: más de 40 años gestionando y alquilando naves industriales propias en la Comunidad de Madrid. Conoce nuestra historia, estructura y equipo directivo.';

const sociedades = [
  'Inversora de Arriendos Inmobiliarios S.L.',
  'Sofía 54 S.L.',
  'Isla Cristina Inversiones S.L.',
  'C.B La Granja 22',
];

const consejo = [
  { name: 'Jose Antonio Martín Borregón', role: 'Consejero Delegado' },
  { name: 'Juan Carlos Martín Borregón', role: 'Director Comercial y Técnico' },
  { name: 'Jose Ramón Corregel Barrio', role: 'Secretario no Consejero' },
];

const valores = [
  {
    title: 'Gestión Directa y Transparente',
    desc: 'Trato personal y ágil, sin intermediarios.',
  },
  {
    title: 'Naves Listas para Usar',
    desc: 'Reformadas, seguras y operativas desde el primer día.',
  },
  {
    title: 'Adaptabilidad por Empresa',
    desc: 'Espacios versátiles para cualquier tipo de actividad.',
  },
];

const timeline = [
  'Más de 40 años de trayectoria en el sector logístico-industrial.',
  'Pioneros en la ordenación urbanística del polígono de Alcobendas.',
  'Cartera consolidada de naves propias en ubicaciones estratégicas.',
  'Relaciones de largo plazo con empresas e inquilinos de referencia.',
];

const aboutImage = `${MEDIA_BASE}Aragoneses/Material-Complejo/Grupo_Sofia54_C_Aragoneses-005.jpg`;
---

<Base title="Sobre Nosotros" description={description} path="/sobre-nosotros/">
  <div class="pg sb">
    <header class="pg-hero sb-hero">
      <div class="pg-container sb-hero-grid">
        <div>
          <span class="pg-eyebrow"><span></span>Sobre Nosotros</span>
          <h1 class="pg-hero-title">Más de cuatro décadas impulsando actividad industrial</h1>
          <p class="pg-hero-sub">
            Somos un grupo empresarial especializado en gestionar y alquilar naves
            industriales propias en la Comunidad de Madrid, con estructura sólida,
            visión de largo plazo y trato directo.
          </p>
          <a class="pg-cta" href="/contacto/">Hablar con el equipo</a>
        </div>
        <img src={aboutImage} alt="Complejo industrial Grupo Sofía54" loading="lazy" />
      </div>
    </header>

    <section class="pg-section">
      <div class="pg-container">
        <h2 class="pg-section-title">Historia y trayectoria</h2>
        <div class="pg-prose">
          <p>
            Con más de <strong>40 años de experiencia</strong>, Grupo SOFIA54 se ha
            consolidado como un referente en el tejido industrial madrileño.
          </p>
        </div>

        <div class="sb-timeline">
          {
            timeline.map((item, idx) => (
              <article>
                <span>{String(idx + 1).padStart(2, '0')}</span>
                <p>{item}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="pg-section pg-section--surface">
      <div class="pg-container">
        <h2 class="pg-section-title pg-section-title--center">Estructura del Grupo</h2>
        <p class="pg-hero-sub" style="margin:0 auto;text-align:center;max-width:720px;">
          Organizamos nuestra gestión mediante sociedades especializadas para dar
          estabilidad, agilidad operativa y continuidad a largo plazo.
        </p>
        <div class="pg-org">
          <div class="pg-org-root">Grupo Sofía 54</div>
          <div class="pg-org-children">
            {sociedades.map((s) => <div class="pg-org-node">{s}</div>)}
          </div>
        </div>
      </div>
    </section>

    <section class="pg-section">
      <div class="pg-container">
        <h2 class="pg-section-title">Equipo directivo</h2>
        <div class="pg-grid pg-grid--3">
          {
            consejo.map((p) => (
              <article class="pg-card">
                <div class="pg-card-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                  </svg>
                </div>
                <h3 class="pg-card-title">{p.name}</h3>
                <p class="pg-card-role">{p.role}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="pg-section pg-section--surface">
      <div class="pg-container">
        <h2 class="pg-section-title">Valores corporativos</h2>
        <div class="pg-prose">
          <p>
            En SOFIA54 combinamos experiencia, rigor y adaptabilidad para ofrecer
            soluciones industriales estables y personalizadas.
          </p>
        </div>

        <div class="sb-claim">
          <span>Escuchamos.</span>
          <span>Nos adaptamos.</span>
          <span>Respondemos.</span>
        </div>

        <div class="pg-grid pg-grid--3">
          {
            valores.map((v) => (
              <article class="pg-card">
                <h3 class="pg-card-title">{v.title}</h3>
                <p class="pg-card-desc">{v.desc}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .sb-hero {
    background: linear-gradient(180deg, #fff, #f6f8fc);
  }
  .sb-hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 28px;
    align-items: center;
  }
  .sb-hero-grid img {
    width: 100%;
    min-height: 340px;
    object-fit: cover;
    border-radius: 18px;
    box-shadow: 0 20px 45px rgba(26, 29, 46, 0.14);
  }
  .sb-timeline {
    margin-top: 26px;
    display: grid;
    gap: 12px;
  }
  .sb-timeline article {
    display: grid;
    grid-template-columns: 46px 1fr;
    gap: 14px;
    align-items: center;
    background: #fff;
    border: 1px solid #e0e3ef;
    border-radius: 12px;
    padding: 14px 16px;
  }
  .sb-timeline span {
    display: inline-flex;
    width: 34px;
    height: 34px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #e8eefa;
    color: #2246f5;
    font-size: 0.76rem;
    font-weight: 700;
  }
  .sb-timeline p {
    margin: 0;
    color: #5a5f78;
    font-size: 0.92rem;
  }
  .sb-claim {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 22px;
    margin: 28px 0 10px;
  }
  .sb-claim span {
    font-size: clamp(1.22rem, 2.4vw, 1.8rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #2246f5;
  }
  @media (max-width: 900px) {
    .sb-hero-grid {
      grid-template-columns: 1fr;
    }
    .sb-hero-grid img {
      min-height: 260px;
    }
  }
</style>
