---
import Base from '../layouts/Base.astro';

const description =
  'Grupo Sofía54: más de 60 naves industriales propias en alquiler en la Comunidad de Madrid. 40+ años de experiencia y 85.000 m² gestionados. Espacios reformados y listos para entrar en Alcobendas, Alcalá de Henares, San Fernando de Henares y Leganés.';
---

<Base title="Inicio" description={description} path="/">
<style is:global>

/* ============================================================
   VARIABLES — coherentes con la web existente
   ============================================================ */
.gs54-inicio * { box-sizing: border-box; margin: 0; padding: 0; }
.gs54-inicio {
  --blue:      #2246f5;
  --blue-dark: #1535c4;
  --blue-bg:   #e8eefa;
  --blue-soft: rgba(34,70,245,0.08);
  --ink:       #1a1d2e;
  --ink-soft:  #5a5f78;
  --ink-light: #9298b0;
  --surface:   #f5f6fa;
  --border:    #e0e3ef;
  --card:      #ffffff;
  --shadow-sm: 0 2px 10px rgba(34,70,245,0.07);
  --shadow-md: 0 8px 30px rgba(34,70,245,0.10);
  --r-sm:      6px;
  --r-md:      12px;
  --r-lg:      20px;
  font-family: 'Inter', -apple-system, Arial, sans-serif;
  background: #ffffff;
  color: var(--ink);
  line-height: 1.6;
}

/* Utilidades */
.gs54-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
}
.gs54-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.70rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  color: var(--blue);
  text-transform: uppercase;
  margin-bottom: 14px;
}
.gs54-eyebrow span { display: inline-block; width: 20px; height: 1px; background: var(--blue); }
.gs54-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--ink);
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: 10px 20px;
  text-decoration: none;
  transition: all 0.17s;
  cursor: pointer;
}
.gs54-btn:hover { border-color: var(--blue); color: var(--blue); }
.gs54-btn-primary {
  color: #fff;
  background: var(--blue);
  border-color: var(--blue);
}
.gs54-btn-primary:hover { background: var(--blue-dark); border-color: var(--blue-dark); color: #fff; }
.gs54-btn svg { flex-shrink: 0; transition: transform 0.17s; }
.gs54-btn:hover svg { transform: translateX(3px); }

/* ============================================================
   1. HERO
   ============================================================ */
.gs54-hero {
  position: relative;
  min-height: 92vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  overflow: hidden;
  background: #ffffff;
}

.gs54-hero-left {
  padding: 100px 0 100px 40px;
  position: relative;
  z-index: 2;
}
.gs54-hero-left .gs54-container { padding: 0; }

.gs54-hero-brand {
  font-size: 0.70rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: var(--ink-light);
  text-transform: uppercase;
  margin-bottom: 28px;
}

.gs54-hero-title {
  font-size: clamp(2.8rem, 5vw, 4.4rem);
  font-weight: 800;
  color: var(--ink);
  line-height: 1.0;
  letter-spacing: -0.03em;
  margin-bottom: 20px;
}
.gs54-hero-title .blue { color: var(--blue); }

.gs54-hero-sub {
  font-size: 1.0rem;
  font-weight: 400;
  color: var(--ink-soft);
  max-width: 400px;
  line-height: 1.70;
  margin-bottom: 36px;
}

.gs54-hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

/* Métricas rápidas bajo CTA */
.gs54-hero-metrics {
  display: flex;
  gap: 32px;
  margin-top: 52px;
  padding-top: 32px;
  border-top: 1px solid var(--border);
}
.gs54-hero-metric-num {
  font-size: 1.7rem;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: -0.03em;
  line-height: 1;
}
.gs54-hero-metric-lbl {
  font-size: 0.73rem;
  color: var(--ink-light);
  margin-top: 3px;
  font-weight: 400;
  line-height: 1.3;
}

/* Panel derecho con imágenes en mosaico */
.gs54-hero-right {
  position: relative;
  height: 100%;
  min-height: 92vh;
  overflow: hidden;
}
.gs54-hero-mosaic {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 4px;
}
.gs54-hero-mosaic-img {
  overflow: hidden;
  position: relative;
}
.gs54-hero-mosaic-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.85);
  transition: filter 0.4s, transform 0.4s;
}
.gs54-hero-mosaic-img:hover img {
  filter: brightness(1);
  transform: scale(1.03);
}
/* Primera imagen ocupa columna completa en la fila 1 */
.gs54-hero-mosaic-img:first-child {
  grid-row: 1 / 3;
}
/* Overlay gradiente izquierdo para transición suave con el texto */
.gs54-hero-right::before {
  content: '';
  position: absolute;
  top: 0; bottom: 0; left: 0;
  width: 80px;
  background: linear-gradient(to right, #ffffff, transparent);
  z-index: 5;
  pointer-events: none;
}

/* ============================================================
   2. COMPROMISO (texto + iconos 3 col)
   ============================================================ */
.gs54-compromiso {
  padding: 80px 0;
  background: #ffffff;
  border-top: 1px solid var(--border);
}
.gs54-compromiso-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.gs54-compromiso-title {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  font-weight: 800;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 16px;
}
.gs54-compromiso-desc {
  font-size: 0.95rem;
  color: var(--ink-soft);
  line-height: 1.72;
  margin-bottom: 28px;
}
.gs54-pillars {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.gs54-pillar {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.gs54-pillar-icon {
  width: 40px;
  height: 40px;
  border-radius: var(--r-sm);
  background: var(--blue-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--blue);
}
.gs54-pillar-title {
  font-size: 0.92rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 3px;
}
.gs54-pillar-desc {
  font-size: 0.83rem;
  color: var(--ink-soft);
  line-height: 1.55;
}

/* ============================================================
   3. CARTERA — stats + grid features
   ============================================================ */
.gs54-cartera {
  padding: 80px 0;
  background: var(--surface);
  border-top: 1px solid var(--border);
}
.gs54-cartera-top {
  text-align: center;
  max-width: 620px;
  margin: 0 auto 52px;
}
.gs54-cartera-title {
  font-size: clamp(1.8rem, 3.5vw, 2.5rem);
  font-weight: 800;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 14px;
}
.gs54-cartera-desc {
  font-size: 0.93rem;
  color: var(--ink-soft);
  line-height: 1.70;
}

/* Stats en fila */
.gs54-stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin-bottom: 52px;
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  overflow: hidden;
  background: var(--border);
}
.gs54-stat-cell {
  background: var(--card);
  padding: 32px 28px;
  text-align: center;
}
.gs54-stat-num {
  font-size: 2.4rem;
  font-weight: 800;
  color: var(--blue);
  letter-spacing: -0.03em;
  line-height: 1;
  margin-bottom: 6px;
}
.gs54-stat-lbl {
  font-size: 0.83rem;
  color: var(--ink-soft);
  font-weight: 400;
  line-height: 1.4;
}

/* Features grid 3x2 */
.gs54-features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.gs54-feature-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 26px 22px;
  transition: box-shadow 0.17s, transform 0.17s;
}
.gs54-feature-card:hover {
  box-shadow: var(--shadow-sm);
  transform: translateY(-2px);
}
.gs54-feature-icon {
  width: 38px;
  height: 38px;
  border-radius: var(--r-sm);
  background: var(--blue-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--blue);
  margin-bottom: 14px;
}
.gs54-feature-title {
  font-size: 0.90rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 6px;
}
.gs54-feature-desc {
  font-size: 0.80rem;
  color: var(--ink-soft);
  line-height: 1.55;
}

/* ============================================================
   4. MAPA / PRESENCIA
   ============================================================ */
.gs54-presencia {
  padding: 80px 0;
  background: #ffffff;
  border-top: 1px solid var(--border);
}
.gs54-presencia-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.gs54-presencia-title {
  font-size: clamp(1.8rem, 3.5vw, 2.5rem);
  font-weight: 800;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 14px;
}
.gs54-presencia-desc {
  font-size: 0.93rem;
  color: var(--ink-soft);
  line-height: 1.70;
  margin-bottom: 28px;
}
/* Mapa SVG Madrid con puntos */
.gs54-mapa-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.gs54-mapa-svg { width: 100%; max-width: 420px; }
/* Puntos de ubicación animados */
.gs54-map-dot {
  animation: gs54Pulse 2.4s ease-in-out infinite;
}
.gs54-map-dot:nth-child(2) { animation-delay: 0.4s; }
.gs54-map-dot:nth-child(3) { animation-delay: 0.8s; }
.gs54-map-dot:nth-child(4) { animation-delay: 1.2s; }
@keyframes gs54Pulse {
  0%, 100% { opacity: 1; r: 5; }
  50%       { opacity: 0.5; r: 7; }
}
.gs54-ubicaciones {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 20px;
}
.gs54-ubicacion-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--ink-soft);
}
.gs54-ubicacion-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--blue);
  flex-shrink: 0;
}

/* ============================================================
   5. CTA INTERMEDIO
   ============================================================ */
.gs54-cta-mid {
  padding: 72px 0;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
.gs54-cta-mid::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 60% 50%, rgba(34,70,245,0.20) 0%, transparent 60%);
  pointer-events: none;
}
.gs54-cta-mid-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}
.gs54-cta-mid-title {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.02em;
  line-height: 1.2;
  max-width: 540px;
}
.gs54-cta-mid-sub {
  font-size: 0.90rem;
  color: rgba(255,255,255,0.55);
  margin-top: 10px;
  max-width: 480px;
  line-height: 1.65;
}
.gs54-btn-white {
  color: var(--ink);
  background: #ffffff;
  border-color: #ffffff;
  flex-shrink: 0;
}
.gs54-btn-white:hover { background: var(--blue-bg); border-color: var(--blue-bg); }

/* ============================================================
   6. PROPUESTA DE VALOR (3 columnas)
   ============================================================ */
.gs54-valor {
  padding: 80px 0;
  background: #ffffff;
  border-top: 1px solid var(--border);
}
.gs54-valor-top {
  text-align: center;
  max-width: 580px;
  margin: 0 auto 52px;
}
.gs54-valor-title {
  font-size: clamp(1.8rem, 3.5vw, 2.5rem);
  font-weight: 800;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 14px;
}
.gs54-valor-desc {
  font-size: 0.93rem;
  color: var(--ink-soft);
  line-height: 1.70;
}
.gs54-valor-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 40px;
}
.gs54-valor-card {
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  overflow: hidden;
}
.gs54-valor-card-img {
  height: 200px;
  overflow: hidden;
  background: var(--surface);
}
.gs54-valor-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.88);
  transition: transform 0.35s, filter 0.35s;
}
.gs54-valor-card:hover .gs54-valor-card-img img {
  transform: scale(1.04);
  filter: brightness(1);
}
.gs54-valor-card-body {
  padding: 20px 20px 22px;
}
.gs54-valor-card-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 6px;
}
.gs54-valor-card-desc {
  font-size: 0.82rem;
  color: var(--ink-soft);
  line-height: 1.58;
}

/* Quote/cita */
.gs54-quote {
  border-left: 3px solid var(--blue);
  padding: 14px 0 14px 24px;
  margin: 40px 0 0;
}
.gs54-quote-text {
  font-size: 1.0rem;
  font-style: italic;
  color: var(--ink-soft);
  line-height: 1.65;
}

/* ============================================================
   7. SOLUCIONES (imagen grande + texto)
   ============================================================ */
.gs54-soluciones {
  padding: 80px 0;
  background: var(--surface);
  border-top: 1px solid var(--border);
}
.gs54-soluciones-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.gs54-soluciones-img-wrap {
  border-radius: var(--r-lg);
  overflow: hidden;
  height: 420px;
  position: relative;
}
.gs54-soluciones-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
/* Badge sobre imagen */
.gs54-soluciones-badge {
  position: absolute;
  bottom: 20px;
  left: 20px;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8px);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 14px 18px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.gs54-soluciones-badge-icon {
  width: 36px; height: 36px;
  border-radius: var(--r-sm);
  background: var(--blue-bg);
  display: flex; align-items: center; justify-content: center;
  color: var(--blue);
  flex-shrink: 0;
}
.gs54-soluciones-badge-text strong {
  display: block;
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--ink);
}
.gs54-soluciones-badge-text span {
  font-size: 0.74rem;
  color: var(--ink-soft);
}

.gs54-soluciones-title {
  font-size: clamp(1.8rem, 3.5vw, 2.5rem);
  font-weight: 800;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 16px;
}
.gs54-soluciones-desc {
  font-size: 0.93rem;
  color: var(--ink-soft);
  line-height: 1.70;
  margin-bottom: 28px;
}
.gs54-soluciones-items {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 32px;
}
.gs54-sol-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--ink-soft);
}
.gs54-sol-item::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--blue);
  flex-shrink: 0;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 900px) {
  .gs54-hero {
    grid-template-columns: 1fr;
    min-height: auto;
  }
  .gs54-hero-right { display: none; }
  .gs54-hero-left { padding: 80px 0 60px; }
  .gs54-hero-metrics { gap: 20px; }

  .gs54-compromiso-inner,
  .gs54-presencia-inner,
  .gs54-soluciones-inner { grid-template-columns: 1fr; gap: 40px; }

  .gs54-stats-row { grid-template-columns: 1fr; }
  .gs54-features-grid { grid-template-columns: 1fr 1fr; }
  .gs54-valor-grid { grid-template-columns: 1fr; }
  .gs54-cta-mid-inner { flex-direction: column; }

  .gs54-soluciones-img-wrap { height: 280px; order: -1; }
}
@media (max-width: 580px) {
  .gs54-container { padding: 0 18px; }
  .gs54-features-grid { grid-template-columns: 1fr; }
  .gs54-hero-metrics { flex-wrap: wrap; gap: 16px; }
  .gs54-hero-actions { flex-direction: column; align-items: flex-start; }
}

</style>

<div class="gs54-inicio">

  <!-- ══════════════════════════════════════════════
       1. HERO
       ══════════════════════════════════════════════ -->
  <section class="gs54-hero">
    <div class="gs54-hero-left">
      <div class="gs54-container">
        <p class="gs54-hero-brand">Grupo SOFIA54</p>
        <h1 class="gs54-hero-title">
          Espacios<br>industriales<br><span class="blue">a tu medida.</span>
        </h1>
        <p class="gs54-hero-sub">Confianza, experiencia y compromiso.<br>Más de 40 años gestionando naves propias en la Comunidad de Madrid.</p>
        <div class="gs54-hero-actions">
          <a href="https://gruposofia54.com/nuestras-naves/" class="gs54-btn gs54-btn-primary">
            Ver Naves Disponibles
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://gruposofia54.com/sobre-nosotros/" class="gs54-btn">Sobre Nosotros</a>
        </div>
        <div class="gs54-hero-metrics">
          <div>
            <div class="gs54-hero-metric-num">+60</div>
            <div class="gs54-hero-metric-lbl">Naves propias</div>
          </div>
          <div>
            <div class="gs54-hero-metric-num">85.000</div>
            <div class="gs54-hero-metric-lbl">m² gestionados</div>
          </div>
          <div>
            <div class="gs54-hero-metric-num">40+</div>
            <div class="gs54-hero-metric-lbl">Años de experiencia</div>
          </div>
        </div>
      </div>
    </div>
    <!-- Panel mosaico de 4 imágenes -->
    <div class="gs54-hero-right">
      <div class="gs54-hero-mosaic">
        <div class="gs54-hero-mosaic-img">
          <img src="https://raw.githubusercontent.com/VIONYX-sol/VYX-s54_website-nuestras_naves/refs/heads/main/Complejos/Aragoneses/Material-Complejo/Grupo_Sofia54_C_Aragoneses-005.jpg" alt="Complejo Aragoneses" loading="eager">
        </div>
        <div class="gs54-hero-mosaic-img">
          <img src="https://raw.githubusercontent.com/VIONYX-sol/VYX-s54_website-nuestras_naves/refs/heads/main/Complejos/La%20Granja/Material%20Complejo/Grupo_Sofia54_C_Granja-010.jpg" alt="Complejo La Granja" loading="eager">
        </div>
        <div class="gs54-hero-mosaic-img">
          <img src="https://raw.githubusercontent.com/VIONYX-sol/VYX-s54_website-nuestras_naves/refs/heads/main/Complejos/Aragoneses/ARAGONESES%207%20POST/FOTOS%20ACTUALES/Grupo_Sofia54_C_Aragoneses-029.jpg" alt="Nave Aragoneses 7 POST" loading="eager">
        </div>
        <div class="gs54-hero-mosaic-img">
          <img src="https://raw.githubusercontent.com/VIONYX-sol/VYX-s54_website-nuestras_naves/refs/heads/main/Complejos/La%20Granja/LA%20GRANJA%2043/FOTOS%20ACTUALES/Grupo_Sofia54_C_Granja-036.jpg" alt="Nave La Granja 43" loading="eager">
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       2. COMPROMETIDOS CON ESPACIOS INDUSTRIALES
       ══════════════════════════════════════════════ -->
  <section class="gs54-compromiso">
    <div class="gs54-container">
      <div class="gs54-compromiso-inner">
        <div>
