---
import Base from '../layouts/Base.astro';
import { MEDIA_BASE } from '../data/site';

const description =
  'Grupo Sofía54: más de 60 naves industriales propias en alquiler en la Comunidad de Madrid. 40+ años de experiencia y 85.000 m² gestionados. Espacios reformados y listos para entrar en Alcobendas, Alcalá de Henares, San Fernando de Henares y Leganés.';

const HERO_VIDEO = '/materialvisual/VYX-s54_website-nuestras_naves-main/Inicio/video-banner_inicial.mp4';

const media = {
  heroPoster: `${MEDIA_BASE}Aragoneses/Material-Complejo/Grupo_Sofia54_C_Aragoneses-005.jpg`,
  about: `${MEDIA_BASE}Aragoneses/Material-Complejo/Grupo_Sofia54_C_Aragoneses-003.jpg`,
  solutions: `${MEDIA_BASE}La%20Granja/Material%20Complejo/Grupo_Sofia54_C_Granja-025.jpg`,
  trust: `${MEDIA_BASE}La%20Granja/LA%20GRANJA%2043/FOTOS%20ACTUALES/Grupo_Sofia54_C_Granja-042.jpg`,
  final: `${MEDIA_BASE}Aragoneses/ARAGONESES%207%20POST/FOTOS%20ACTUALES/Grupo_Sofia54_C_Aragoneses-030.jpg`,
};
---

<Base title="Inicio" description={description} path="/">
  <div class="home">
    <section class="hero">
      <video class="hero-video" autoplay muted loop playsinline preload="metadata" poster={media.heroPoster}>
        <source src={HERO_VIDEO} type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>

      <div class="container hero-content">
        <p class="hero-kicker">Grupo SOFIA54</p>
        <h1>Espacios industriales a tu medida.</h1>
        <p class="hero-sub">Confianza, experiencia y compromiso.</p>
        <div class="hero-actions">
          <a href="/nuestras-naves/" class="btn btn-primary">Ver nuestras naves</a>
          <a href="/contacto/" class="btn btn-ghost">Solicitar información</a>
        </div>
      </div>
    </section>

    <section class="stats">
      <div class="container stats-grid">
        <article><strong>+60</strong><span>Naves propias</span></article>
        <article><strong>85.000</strong><span>m² gestionados</span></article>
        <article><strong>40+</strong><span>Años de experiencia</span></article>
        <article><strong>+60</strong><span>Empresas inquilinas</span></article>
      </div>
    </section>

    <section class="split">
      <div class="container split-grid">
        <div>
          <p class="eyebrow">Sobre nosotros</p>
          <h2>Gestión directa, profesional y sin intermediarios</h2>
          <p>
            Grupo SOFIA54 gestiona y alquila naves propias en la Comunidad de Madrid,
            con soluciones flexibles y espacios reformados para uso industrial,
            logístico, comercial y de oficina.
          </p>
          <a href="/sobre-nosotros/" class="text-link">Conocer el grupo →</a>
        </div>
        <img src={media.about} alt="Complejo industrial de Grupo Sofía54" loading="lazy" />
      </div>
    </section>

    <section class="cards">
      <div class="container">
        <p class="eyebrow">Nuestra propuesta</p>
        <h2>Espacios preparados para crecer con tu empresa</h2>
        <div class="cards-grid">
          <article>
            <img src={media.about} alt="Naves listas para entrar" loading="lazy" />
            <h3>Naves listas para entrar</h3>
            <p>Instalaciones actualizadas, accesos operativos y adaptación por actividad.</p>
          </article>
          <article>
            <img src={media.solutions} alt="Ubicaciones estratégicas" loading="lazy" />
            <h3>Ubicación estratégica</h3>
            <p>Complejos bien conectados con acceso rápido a principales vías y transporte.</p>
          </article>
          <article>
            <img src={media.trust} alt="Empresas que confían en Grupo Sofía54" loading="lazy" />
            <h3>Relación de largo plazo</h3>
            <p>Más de 60 empresas confían en nuestra gestión y atención directa.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="locations">
      <div class="container location-grid">
        <div>
          <p class="eyebrow">Cobertura</p>
          <h2>Presencia estratégica en la Comunidad de Madrid</h2>
          <p>
            Disponemos de espacios en enclaves clave para optimizar operativa,
            distribución y visibilidad de negocio.
          </p>
          <ul>
            <li>Alcobendas</li>
            <li>Alcalá de Henares</li>
            <li>San Fernando de Henares</li>
            <li>Leganés</li>
          </ul>
        </div>
        <div class="location-panel">
          <h3>¿Buscas una nave disponible ahora?</h3>
          <p>Filtra por ubicación y características para ver opciones activas.</p>
          <a href="/nuestras-naves/" class="btn btn-primary">Explorar naves</a>
        </div>
      </div>
    </section>

    <section class="final-cta">
      <img src={media.final} alt="Nave industrial Grupo Sofía54" loading="lazy" />
      <div class="final-overlay">
        <div class="container final-content">
          <h2>Espacios industriales con identidad, servicio y continuidad</h2>
          <p>Te ayudamos a encontrar una nave alineada con tu operativa real.</p>
          <a href="/contacto/" class="btn btn-primary">Hablar con el equipo</a>
        </div>
      </div>
    </section>
  </div>
</Base>

<style is:global>
  .home {
    --blue: #2246f5;
    --blue-dark: #1535c4;
    --ink: #101424;
    --ink-soft: #56607a;
    --surface: #f4f7fb;
    --border: #e0e6f0;
  }
  .container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 999px;
    padding: 12px 22px;
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
    transition: 0.2s ease;
    border: 1px solid transparent;
  }
  .btn-primary {
    background: var(--blue);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--blue-dark);
  }
  .btn-ghost {
    border-color: rgba(255, 255, 255, 0.45);
    color: #fff;
    backdrop-filter: blur(8px);
    background: rgba(255, 255, 255, 0.08);
  }
  .btn-ghost:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.18);
  }
  .eyebrow {
    margin: 0 0 10px;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: var(--blue);
  }

  .hero {
    min-height: calc(100vh - 68px);
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: #fff;
    border-bottom: 1px solid var(--border);
  }
  .hero-video,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }
  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    background: linear-gradient(115deg, rgba(10, 14, 26, 0.82) 20%, rgba(10, 14, 26, 0.35) 75%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 82px;
    padding-bottom: 82px;
    max-width: 760px;
  }
  .hero-kicker {
    margin: 0 0 14px;
    text-transform: uppercase;
    letter-spacing: 0.19em;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.82);
  }
  .hero h1 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }
  .hero-sub {
    margin: 14px 0 28px;
    color: rgba(255, 255, 255, 0.87);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .stats {
    background: #fff;
    border-bottom: 1px solid var(--border);
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    padding-top: 34px;
    padding-bottom: 34px;
  }
  .stats article {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .stats strong {
    font-size: 1.55rem;
    color: var(--ink);
  }
  .stats span {
    font-size: 0.84rem;
    color: var(--ink-soft);
  }

  .split,
  .cards,
  .locations {
    padding: 74px 0;
    border-bottom: 1px solid var(--border);
  }
  .split-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 34px;
  }
  .split h2,
  .cards h2,
  .locations h2,
  .final-content h2 {
    margin: 0 0 14px;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.14;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .split p,
  .cards p,
  .locations p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.7;
  }
  .split img {
    border-radius: 18px;
    width: 100%;
    min-height: 340px;
    object-fit: cover;
    box-shadow: 0 25px 50px rgba(16, 20, 36, 0.12);
  }
  .text-link {
    display: inline-flex;
    margin-top: 18px;
    font-weight: 700;
    text-decoration: none;
  }

  .cards {
    background: var(--surface);
  }
  .cards-grid {
    margin-top: 30px;
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .cards article {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }
  .cards img {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }
  .cards h3 {
    margin: 18px 18px 8px;
    font-size: 1.06rem;
    color: var(--ink);
  }
  .cards article p {
    margin: 0 18px 20px;
    font-size: 0.92rem;
  }

  .location-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: stretch;
  }
  .locations ul {
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 9px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .locations li {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 9px 14px;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--ink);
  }
  .location-panel {
    border: 1px solid var(--border);
    border-radius: 18px;
    background: linear-gradient(150deg, #fff, #eef3ff);
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .location-panel h3 {
    margin: 0 0 10px;
    font-size: 1.25rem;
    color: var(--ink);
  }
  .location-panel p {
    margin-bottom: 20px;
  }

  .final-cta {
    position: relative;
    min-height: 58vh;
    overflow: hidden;
  }
  .final-cta img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .final-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(95deg, rgba(10, 14, 26, 0.85), rgba(10, 14, 26, 0.36));
    display: flex;
    align-items: center;
  }
  .final-content {
    color: #fff;
    max-width: 760px;
  }
  .final-content h2 {
    color: #fff;
  }
  .final-content p {
    margin: 0 0 22px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
  }

  @media (max-width: 980px) {
    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .split-grid,
    .location-grid,
    .cards-grid {
      grid-template-columns: 1fr;
    }
    .split img {
      min-height: 280px;
    }
  }
  @media (max-width: 680px) {
    .container {
      padding: 0 20px;
    }
    .hero {
      min-height: 74vh;
    }
    .hero-actions,
    .btn {
      width: 100%;
    }
    .locations ul {
      grid-template-columns: 1fr;
    }
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
