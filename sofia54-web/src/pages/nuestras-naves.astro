<!-- LIGHTBOX (fuera del contenedor principal) -->
<div class="gs54-lbx-overlay" id="gs54-lbx" role="dialog" aria-modal="true" aria-label="Visor de imágenes">
  <div class="gs54-lbx-toolbar">
