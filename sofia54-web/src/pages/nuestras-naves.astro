---
import Base from '../layouts/Base.astro';
import data from '../data/complejos.json';
import { MEDIA_BASE } from '../data/site';

const description =
  'Catálogo de naves industriales en alquiler de Grupo Sofía54 en la Comunidad de Madrid. Filtra por complejo, superficie, disponibilidad y características. Naves en Alcobendas con fichas comerciales y planos descargables.';

// Reconstruye el array DATA con URLs absolutas a partir de MEDIA_BASE.
// Para migrar a CDN, basta con cambiar MEDIA_BASE en src/data/site.ts.
const DATA = data.complejos.map((cp) => ({
  id: cp.id,
  nombre: cp.nombre,
  ciudad: cp.ciudad,
  descripcion: cp.descripcion,
  caracteristicas: cp.caracteristicas,
  badges: cp.badges,
  video: cp.video ? MEDIA_BASE + cp.video : null,
  fotos: (cp.fotos || []).map((f) => MEDIA_BASE + f),
  docsComplejo: cp.docsComplejo || [],
  naves: (cp.naves || []).map((n) => ({
    titulo: n.titulo,
    m2: n.m2,
    disponible: n.disponible,
    desc: n.desc,
    caracteristicas: n.caracteristicas,
    imgs: (n.imgs || []).map((i) => MEDIA_BASE + i),
    ficha: n.ficha ? MEDIA_BASE + n.ficha : null,
    planos: (n.planos || []).map((p) => ({ l: p.l, u: MEDIA_BASE + p.u })),
  })),
}));
---

<Base title="Nuestras Naves" description={description} path="/nuestras-naves/">
<style is:global>

/* ============================================================
   RESET & ROOT
   ============================================================ */
.gs54-naves * { box-sizing: border-box; margin: 0; padding: 0; }
.gs54-naves {
  --blue:       #2246f5;
  --blue-dark:  #1535c4;
  --blue-bg:    #e8eefa;
  --blue-soft:  rgba(34,70,245,0.08);
  --ink:        #1a1d2e;
  --ink-soft:   #5a5f78;
  --ink-light:  #8a8fa8;
  --surface:    #f5f6fa;
  --card:       #ffffff;
  --border:     #e0e3ef;
  --border-b:   rgba(34,70,245,0.14);
  --green:      #1a6e3e;
  --green-bg:   #e6f4ec;
  --red:        #a82e2e;
  --red-bg:     #faeaea;
  --shadow-xs:  0 1px 4px rgba(0,0,0,0.06);
  --shadow-sm:  0 2px 10px rgba(34,70,245,0.07);
  --shadow-md:  0 6px 24px rgba(34,70,245,0.11);
  --r-sm:       6px;
  --r-md:       12px;
  --r-lg:       18px;
  font-family: 'Inter', -apple-system, Arial, sans-serif;
  background: #ffffff;
  color: var(--ink);
}

/* ============================================================
   CABECERA — limpia, sin degradado, coherente con la web
   ============================================================ */
.gs54-header {
  padding: 56px 32px 48px;
  border-bottom: 1px solid var(--border);
  background: #ffffff;
}
.gs54-header-inner {
  max-width: 1160px;
  margin: 0 auto;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.gs54-header-left {}
.gs54-header-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  color: var(--blue);
  text-transform: uppercase;
  margin-bottom: 12px;
}
.gs54-header-eyebrow span {
  display: inline-block;
  width: 24px;
  height: 1px;
  background: var(--blue);
}
.gs54-main-title {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  color: var(--ink);
  line-height: 1.1;
  letter-spacing: -0.02em;
}
.gs54-main-title strong {
  color: var(--blue);
  font-weight: 700;
}
.gs54-subtitle {
  font-size: 0.95rem;
  font-weight: 400;
  color: var(--ink-soft);
  margin-top: 10px;
  max-width: 480px;
  line-height: 1.65;
}
/* Stats eliminados — se añadirán cuando estén todos los complejos */

/* ============================================================
   FILTROS — sobre superficie blanca/gris muy suave
   ============================================================ */
.gs54-filters-wrap {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 18px 32px;
}
.gs54-filters-inner {
  max-width: 1160px;
  margin: 0 auto;
  display: flex;
  flex-wrap: wrap;
  gap: 18px;
  align-items: flex-end;
}
.gs54-filter-group { display: flex; flex-direction: column; gap: 5px; }
.gs54-filter-label {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  color: var(--ink-light);
  text-transform: uppercase;
}
.gs54-chips { display: flex; flex-wrap: wrap; gap: 5px; }
.gs54-chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.79rem;
  font-weight: 500;
  color: var(--ink-soft);
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: 40px;
  padding: 5px 12px;
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
  user-select: none;
}
.gs54-chip:hover {
  color: var(--blue);
  border-color: var(--blue);
  background: var(--blue-bg);
}
.gs54-chip.active {
  color: #ffffff;
  background: var(--blue);
  border-color: var(--blue);
  font-weight: 600;
}

.gs54-filter-sep {
  width: 1px;
  background: var(--border);
  align-self: stretch;
  margin: 0 2px;
}
.gs54-m2-range { display: flex; align-items: center; gap: 6px; }
.gs54-m2-range input {
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: 5px 10px;
  font-family: 'Inter', sans-serif;
  font-size: 0.79rem;
  color: var(--ink);
  width: 70px;
  outline: none;
  transition: border-color 0.15s;
}
.gs54-m2-range input:focus { border-color: var(--blue); }
.gs54-m2-range input::placeholder { color: var(--ink-light); }
.gs54-m2-dash { color: var(--ink-light); font-size: 0.85rem; }

.gs54-reset-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: 'Inter', sans-serif;
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--ink-soft);
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 40px;
  padding: 6px 14px;
  cursor: pointer;
  transition: all 0.15s;
}
.gs54-reset-btn:hover { color: var(--blue); border-color: var(--blue); }

/* ============================================================
   SIN RESULTADOS
   ============================================================ */
.gs54-no-results {
  text-align: center;
  padding: 72px 24px;
  color: var(--ink-soft);
}
.gs54-no-results strong {
  display: block;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 8px;
}

/* ============================================================
   LAYOUT PRINCIPAL
   ============================================================ */
.gs54-localizacion {
  max-width: 1160px;
  margin: 0 auto;
  padding: 52px 32px 80px;
  display: flex;
  flex-direction: column;
  gap: 80px;
}

/* ============================================================
   BLOQUE COMPLEJO
   ============================================================ */
.gs54-complejo-block {}

/* -------- HERO VIDEO + FOTOS (composición elegante) -------- */
.gs54-complejo-visual {
  display: grid;
  /* vídeo ocupa 3/4, panel fotos 1/4 */
  grid-template-columns: 1fr 220px;
  grid-template-rows: 360px;
  border-radius: var(--r-lg);
  overflow: hidden;
  position: relative;
}

/* Celda vídeo */
.gs54-hero-video-wrap {
  position: relative;
  overflow: hidden;
  background: var(--ink);
}
.gs54-hero-video-wrap video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.60;
}
.gs54-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    110deg,
    rgba(26,29,46,0.82) 0%,
    rgba(26,29,46,0.20) 70%
  );
}
.gs54-hero-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 32px 36px;
}
.gs54-hero-eyebrow {
  font-size: 0.67rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  color: rgba(255,255,255,0.50);
  text-transform: uppercase;
  margin-bottom: 7px;
}
.gs54-hero-nombre {
  font-size: clamp(1.8rem, 3.5vw, 3rem);
  font-weight: 700;
  color: #ffffff;
  line-height: 1.0;
  letter-spacing: -0.01em;
}
.gs54-hero-ciudad {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.45);
  margin-top: 5px;
}
.gs54-hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 14px;
}
.gs54-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 40px;
  padding: 4px 10px;
  font-size: 0.73rem;
  color: rgba(255,255,255,0.80);
  font-weight: 500;
  white-space: nowrap;
}

/* Celda fotos — panel lateral elegante */
.gs54-fotos-panel {
  display: flex;
  flex-direction: column;
  gap: 3px;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
.gs54-fotos-panel img {
  flex: 1;
  width: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.65) saturate(0.85);
  transition: filter 0.3s;
}
.gs54-fotos-panel img:hover {
  filter: brightness(0.85) saturate(1);
  z-index: 2;
}
/* Línea azul decorativa entre vídeo y fotos */
.gs54-fotos-panel::before {
  content: '';
  position: absolute;
  left: 0; top: 10%; bottom: 10%;
  width: 2px;
  background: var(--blue);
  z-index: 5;
  opacity: 0.7;
}

/* Responsive: en móvil las fotos desaparecen del grid */
@media (max-width: 768px) {
  .gs54-complejo-visual {
    grid-template-columns: 1fr;
    grid-template-rows: 260px;
  }
  .gs54-fotos-panel { display: none; }
}

/* -------- META Y DESCRIPCIÓN -------- */
.gs54-complejo-meta {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 14px;
  margin: 22px 0 0;
}
.gs54-complejo-desc {
  font-size: 0.90rem;
  color: var(--ink-soft);
  line-height: 1.70;
  max-width: 620px;
}
.gs54-doc-group { display: flex; flex-wrap: wrap; gap: 7px; }
.gs54-doc-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.74rem;
  font-weight: 600;
  color: var(--blue);
  background: var(--blue-bg);
  border: 1px solid var(--border-b);
  border-radius: var(--r-sm);
  padding: 6px 12px;
  text-decoration: none;
  transition: background 0.14s;
}
.gs54-doc-btn:hover { background: #d6e0fc; }

/* ============================================================
   DIVISOR NAVES
   ============================================================ */
.gs54-naves-hdr {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 28px 0 16px;
}
.gs54-naves-hdr-txt {
  font-size: 0.70rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  color: var(--ink-light);
  text-transform: uppercase;
  white-space: nowrap;
}
.gs54-naves-hdr-line { flex: 1; height: 1px; background: var(--border); }
.gs54-naves-hdr-count {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--blue);
  background: var(--blue-bg);
  border: 1px solid var(--border-b);
  border-radius: 40px;
  padding: 2px 10px;
  white-space: nowrap;
}

/* ============================================================
   SCROLL NAVES con flechas laterales siempre visibles
   ============================================================ */
.gs54-scroll-outer {
  position: relative;
}
/* Flechas laterales de scroll */
.gs54-scroll-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-md);
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.16s;
  font-size: 1rem;
}
.gs54-scroll-arrow:hover {
  background: var(--blue);
  color: #ffffff;
  border-color: var(--blue);
}
.gs54-scroll-arrow.left  { left: -18px; }
.gs54-scroll-arrow.right { right: -18px; }
.gs54-scroll-arrow.hidden { opacity: 0; pointer-events: none; }

/* Degradado de fade en los bordes para indicar scroll */
.gs54-scroll-outer::before,
.gs54-scroll-outer::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 40px;
  z-index: 5;
  pointer-events: none;
  transition: opacity 0.2s;
}
.gs54-scroll-outer::before {
  left: 0;
  background: linear-gradient(to right, #ffffff, transparent);
}
.gs54-scroll-outer::after {
  right: 0;
  background: linear-gradient(to left, #ffffff, transparent);
}
.gs54-scroll-outer.at-start::before { opacity: 0; }
.gs54-scroll-outer.at-end::after    { opacity: 0; }

.gs54-naves-scroll {
  overflow-x: auto;
  padding: 6px 2px 14px;
  scrollbar-width: none;   /* ocultar scrollbar nativa — las flechas la reemplazan */
  -ms-overflow-style: none;
  scroll-behavior: smooth;
}
.gs54-naves-scroll::-webkit-scrollbar { display: none; }

.gs54-naves-grid {
  display: flex;
  flex-wrap: nowrap;
  gap: 16px;
  width: max-content;
}

/* ============================================================
   TARJETA NAVE
   ============================================================ */
.gs54-nave-card {
  width: 292px;
  flex-shrink: 0;
  background: var(--card);
  border-radius: var(--r-md);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-xs);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.16s, box-shadow 0.16s;
}
.gs54-nave-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
}

/* Carrusel */
.gs54-carrusel {
  position: relative;
  width: 100%;
  height: 188px;
  background: var(--surface);
  overflow: hidden;
  flex-shrink: 0;
}
.gs54-carrusel img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.5s ease;
}
.gs54-carrusel img.active { opacity: 1; z-index: 1; }

.gs54-carr-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  background: rgba(255,255,255,0.85);
  border: none;
  color: var(--ink);
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: none;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 0.85rem;
  transition: background 0.14s;
  box-shadow: var(--shadow-xs);
}
.gs54-carrusel:hover .gs54-carr-arrow { display: flex; }
.gs54-carr-arrow:hover { background: var(--blue); color: #fff; }
.gs54-carr-arrow.left  { left: 7px; }
.gs54-carr-arrow.right { right: 7px; }

.gs54-carr-dots {
  position: absolute;
  bottom: 7px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  gap: 4px;
}
.gs54-carr-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,0.45);
  cursor: pointer;
  transition: background 0.16s, transform 0.16s;
}
.gs54-carr-dot.active { background: #fff; transform: scale(1.3); }

.gs54-carrusel-noimg {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--ink-light);
  font-size: 0.75rem;
  gap: 8px;
}

/* Cuerpo */
.gs54-nave-body {
  padding: 15px 16px 12px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.gs54-nave-title {
  font-size: 1.02rem;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.2;
}
.gs54-nave-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 6px;
}
.gs54-nave-m2 {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--blue);
}
.gs54-nave-m2 sup {
  font-size: 0.62rem;
  font-weight: 500;
  color: var(--ink-soft);
}
.gs54-nave-estado {
  font-size: 0.70rem;
  font-weight: 600;
  padding: 2px 9px;
  border-radius: 40px;
  letter-spacing: 0.03em;
}
.gs54-estado-disponible { background: var(--green-bg); color: var(--green); border: 1px solid rgba(26,110,62,0.16); }
.gs54-estado-ocupada    { background: var(--red-bg);   color: var(--red);   border: 1px solid rgba(168,46,46,0.16); }

.gs54-nave-desc {
  font-size: 0.78rem;
  color: var(--ink-soft);
  line-height: 1.55;
}

/* Footer docs */
.gs54-nave-footer {
  border-top: 1px solid var(--border);
  padding: 10px 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}
.gs54-nave-doc-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.69rem;
  font-weight: 600;
  color: var(--blue);
  background: var(--blue-bg);
  border: 1px solid var(--border-b);
  border-radius: 4px;
  padding: 4px 9px;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.13s;
  font-family: 'Inter', sans-serif;
}
.gs54-nave-doc-btn:hover { background: #d6e0fc; }

/* Panel planos desplegable */
.gs54-planos-panel {
  display: none;
  flex-wrap: wrap;
  gap: 5px;
  padding: 8px 16px 12px;
  border-top: 1px solid var(--border);
  background: var(--surface);
}

/* ============================================================
   ETIQUETA CIUDAD (encima de cada complejo)
   ============================================================ */
.gs54-ciudad-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.71rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  color: var(--ink-light);
  text-transform: uppercase;
  margin-bottom: 12px;
}



/* ============================================================
   LIGHTBOX
   ============================================================ */
.gs54-lbx-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
  background: rgba(10,12,22,0.92);
  backdrop-filter: blur(6px);
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 20px;
  animation: gs54LbxFadeIn 0.22s ease;
}
.gs54-lbx-overlay.open { display: flex; }
@keyframes gs54LbxFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* Toolbar superior */
.gs54-lbx-toolbar {
  position: absolute;
  top: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  background: linear-gradient(to bottom, rgba(10,12,22,0.70), transparent);
  z-index: 2;
}
.gs54-lbx-title {
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  font-weight: 500;
  color: rgba(255,255,255,0.70);
  max-width: 60%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.gs54-lbx-counter {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.40);
  margin-left: auto;
  margin-right: 16px;
}
.gs54-lbx-close {
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.80);
  width: 36px; height: 36px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  font-size: 1.1rem;
  transition: background 0.15s;
  flex-shrink: 0;
}
.gs54-lbx-close:hover { background: rgba(255,255,255,0.22); color: #fff; }

/* Media principal */
.gs54-lbx-media {
  max-width: min(92vw, 1100px);
  max-height: calc(100vh - 100px);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.gs54-lbx-media img {
  max-width: 100%;
  max-height: calc(100vh - 110px);
  object-fit: contain;
  border-radius: 8px;
  display: block;
  box-shadow: 0 24px 80px rgba(0,0,0,0.50);
  animation: gs54LbxSlideIn 0.20s ease;
}
.gs54-lbx-media video {
  max-width: 100%;
  max-height: calc(100vh - 110px);
  border-radius: 8px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.50);
  outline: none;
}
@keyframes gs54LbxSlideIn {
  from { opacity: 0; transform: scale(0.96); }
  to   { opacity: 1; transform: scale(1); }
}

/* Flechas navegación lightbox */
.gs54-lbx-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.80);
  width: 44px; height: 44px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  font-size: 1.1rem;
  transition: background 0.15s;
  z-index: 3;
}
.gs54-lbx-nav:hover { background: rgba(34,70,245,0.65); color: #fff; border-color: transparent; }
.gs54-lbx-nav.prev { left: -60px; }
.gs54-lbx-nav.next { right: -60px; }
.gs54-lbx-nav.hidden { opacity: 0; pointer-events: none; }

/* Thumbnails strip */
.gs54-lbx-thumbs {
  display: flex;
  gap: 8px;
  margin-top: 14px;
  max-width: min(92vw, 1100px);
  overflow-x: auto;
  padding: 4px 2px 8px;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.15) transparent;
}
.gs54-lbx-thumbs::-webkit-scrollbar { height: 3px; }
.gs54-lbx-thumbs::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); }
.gs54-lbx-thumb {
  flex-shrink: 0;
  width: 64px;
  height: 44px;
  border-radius: 5px;
  overflow: hidden;
  cursor: pointer;
  border: 2px solid transparent;
  opacity: 0.5;
  transition: opacity 0.15s, border-color 0.15s;
  background: rgba(255,255,255,0.05);
  display: flex; align-items: center; justify-content: center;
}
.gs54-lbx-thumb img {
  width: 100%; height: 100%;
  object-fit: cover;
  border-radius: 3px;
}
.gs54-lbx-thumb.video-thumb {
  color: rgba(255,255,255,0.5);
  font-size: 0.62rem;
  font-family: 'Inter', sans-serif;
  flex-direction: column;
  gap: 2px;
}
.gs54-lbx-thumb.active {
  opacity: 1;
  border-color: var(--blue);
}
.gs54-lbx-thumb:hover { opacity: 0.85; }

/* Responsive lightbox */
@media (max-width: 640px) {
  .gs54-lbx-nav.prev { left: 4px; }
  .gs54-lbx-nav.next { right: 4px; }
  .gs54-lbx-nav { width: 36px; height: 36px; font-size: 0.9rem; }
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 640px) {
  .gs54-header { padding: 36px 18px 32px; }
  .gs54-filters-wrap { padding: 16px 18px; }
  .gs54-localizacion { padding: 36px 18px 60px; gap: 60px; }
  .gs54-scroll-arrow { display: none; }
  .gs54-scroll-outer::before,
  .gs54-scroll-outer::after { display: none; }
  .gs54-naves-scroll { padding-bottom: 10px; scrollbar-width: thin; }
  .gs54-nave-card { width: 264px; }
  .gs54-header-stats { display: none; }
}
</style>

<div class="gs54-naves" id="nuestras-naves">

